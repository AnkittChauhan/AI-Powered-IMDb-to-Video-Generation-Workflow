# Shared local Docker Compose environment
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Local TTS through Kokoro FastAPI
TTS_PROVIDER=kokoro
KOKORO_IMAGE=ghcr.io/remsky/kokoro-fastapi-cpu:v0.3.0
KOKORO_TTS_BASE_URL=http://kokoro_tts:8880/v1
KOKORO_TTS_API_KEY=not-needed
KOKORO_TTS_MODEL=kokoro
KOKORO_TTS_VOICE=af_sky
KOKORO_TTS_FORMAT=mp3
KOKORO_TTS_SPEED=1.0

# Use these for script generation through OpenRouter:
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=openrouter-api-key-here
# OPENROUTER_MODEL=openrouter/owl-alpha
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Visual generation
# scene_card is the free local default. If you run ComfyUI separately
# outside this Docker Compose stack, point COMFYUI_BASE_URL to that endpoint.
# VISUAL_PROVIDER=ai_image
# AI_IMAGE_PROVIDER=local_comfyui
# AI_IMAGE_SIZE=1024x1024
# COMFYUI_BASE_URL=http://host.docker.internal:8188
# COMFYUI_CHECKPOINT=sd_xl_base_1.0.safetensors

# Frontend public API URL used by the browser
NEXT_PUBLIC_API_URL=http://localhost:8000

# Local database credentials used by docker-compose.yml
POSTGRES_DB=imdb_video
POSTGRES_USER=imdb_user
POSTGRES_PASSWORD=change-me-for-non-local-use
