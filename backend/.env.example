# API Configuration
API_TITLE=IMDb Video Generator
API_VERSION=0.1.0
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///./imdb_video.db
SQLALCHEMY_ECHO=False

# Redis & Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# OpenAI API
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Local TTS through Kokoro FastAPI
TTS_PROVIDER=kokoro
TTS_MAX_CHARACTERS=2000
KOKORO_TTS_BASE_URL=http://kokoro_tts:8880/v1
KOKORO_TTS_API_KEY=not-needed
KOKORO_TTS_MODEL=kokoro
KOKORO_TTS_VOICE=af_sky
KOKORO_TTS_FORMAT=mp3
KOKORO_TTS_SPEED=1.0

# OpenRouter API for script generation
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=openrouter-api-key-here
# OPENROUTER_MODEL=openrouter/owl-alpha
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# File Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=/tmp/imdb_video_storage

# Job Configuration
JOB_TIMEOUT_SECONDS=3600
ADMIN_TOKEN=change-me

# Logging
LOG_LEVEL=INFO

# Development
DEBUG=True
